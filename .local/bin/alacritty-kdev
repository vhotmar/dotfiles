#!/usr/bin/env bash
set -euo pipefail

export PATH="/etc/profiles/per-user/vhotmar/bin:/run/current-system/sw/bin:$PATH"
export LIMA_HOME="${LIMA_HOME:-/Volumes/T7/lima}"

exec alacritty \
  --title "kdev - lima" \
  --config-file ~/.config/alacritty/alacritty-kdev.toml \
  -e limactl shell kdev -- tmux new-session -A -s kdev
