#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$HOME/main/dotfiles"

cd "$DOTFILES_DIR"

echo "Updating flake inputs..."
nix flake update

case "$(uname -s)" in
  Darwin)
    echo "Rebuilding darwin configuration..."
    sudo darwin-rebuild switch --flake .#macbook
    ;;
  Linux)
    echo "Switching home-manager configuration (lima)..."
    home-manager switch --flake .#vhotmar@lima
    ;;
  *)
    echo "Unsupported platform: $(uname -s)" >&2
    exit 1
    ;;
esac

echo "Done!"
